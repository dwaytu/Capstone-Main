{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SENTINEL",
  "version": "1.0.0",
  "identifier": "com.sentinel.ops.desktop",
  "build": {
    "frontendDist": "../../../DasiaAIO-Frontend/app-dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "SENTINEL",
        "width": 1600,
        "height": 960,
        "minWidth": 1280,
        "minHeight": 800,
        "fullscreen": false,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
