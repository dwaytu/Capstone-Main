{
  "version": "1.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "release:version": "node scripts/release-version.js",
    "release:sync-version": "node scripts/sync-release-version.js",
    "release:notes": "node scripts/generate-release-notes.js",
    "release:rename-artifact": "node scripts/rename-artifacts.js",
    "verify:all": "powershell -ExecutionPolicy Bypass -File scripts/codex-verify.ps1",
    "verify:capstone:quick": "powershell -ExecutionPolicy Bypass -File scripts/capstone-readiness.ps1 -Mode quick",
    "verify:capstone:full": "powershell -ExecutionPolicy Bypass -File scripts/capstone-readiness.ps1 -Mode full",
    "deploy:railway": "powershell -ExecutionPolicy Bypass -File scripts/railway-deploy.ps1 -Target both",
    "deploy:railway:backend": "powershell -ExecutionPolicy Bypass -File scripts/railway-deploy.ps1 -Target backend",
    "deploy:railway:frontend": "powershell -ExecutionPolicy Bypass -File scripts/railway-deploy.ps1 -Target frontend",
    "build:web": "npm run build:web --prefix DasiaAIO-Frontend",
    "build:android": "npm run build:android --prefix DasiaAIO-Frontend",
    "build:desktop": "npm run build:desktop --prefix DasiaAIO-Frontend",
    "release:web": "npm run release:web --prefix DasiaAIO-Frontend",
    "release:desktop": "npm run release:desktop --prefix DasiaAIO-Frontend",
    "release:android": "npm run release:android --prefix DasiaAIO-Frontend",
    "release:android:bundle": "npm run release:android:bundle --prefix DasiaAIO-Frontend",
    "release:all": "npm run release:all --prefix DasiaAIO-Frontend"
  },
  "dependencies": {
    "pg": "^8.19.0"
  }
}
